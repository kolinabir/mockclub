# ─── Core ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Database ──────────────────────────────────────────────────────────────
# Free Atlas M0 works. Transactions need a replica set — Atlas is one,
# a local standalone `mongod` is NOT.
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/mockclub"

# ─── Auth (Better Auth) ────────────────────────────────────────────────────
# openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
