# ─── Core ──────────────────────────────────────────────────────────────────
# The canonical origin. Set this to your real domain in production — it drives
# canonical URLs, the sitemap, robots.txt, OG images and JSON-LD.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Analytics (optional) ──────────────────────────────────────────────────
# Google Analytics 4 measurement ID. Leave blank to disable analytics entirely.
NEXT_PUBLIC_GA_ID=""

# ─── Database ──────────────────────────────────────────────────────────────
# Free Atlas M0 works. Transactions need a replica set — Atlas is one,
# a local standalone `mongod` is NOT.
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/mockclub"

# ─── Auth (Better Auth) ────────────────────────────────────────────────────
# openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (sign-in only — openid/email/profile, all NON-sensitive scopes,
# so no Google verification review is required).
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Redirect URI must be exactly: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
# NEVER commit a real value and NEVER prefix with NEXT_PUBLIC_ (that ships it
# to the browser).
GOOGLE_CLIENT_SECRET=""

# ─── Email (optional in development) ───────────────────────────────────────
# Any SMTP provider. Leave these blank and mail is DISABLED rather than broken:
# the signup flow still runs end to end and the server log records the email
# that would have gone out. All five below are required together — miss one and
# the whole transport stays off.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# The visible sender. Either form works: "contact@example.com" or
# "MockClub <contact@example.com>".
EMAIL_FROM=""

# Where replies go, if that differs from EMAIL_FROM. Blank = replies to sender.
EMAIL_REPLY_TO=""

# Base URL for links inside emails. Defaults to NEXT_PUBLIC_APP_URL, which is
# correct in production. Set this only when that value is not publicly
# reachable — a localhost link in a real email is dead on arrival.
EMAIL_BASE_URL=""

# ─── Cron ──────────────────────────────────────────────────────────────────
# Shared secret for the nightly slot sweep (/api/cron/slots, scheduled in
# vercel.json). The route FAILS CLOSED: leave this unset and the sweep can
# never run — including for you — so interviewers silently run out of bookable
# hours about a month in. Set it in production.
#   openssl rand -base64 32
# Vercel Cron sends it automatically as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=""